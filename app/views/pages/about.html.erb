<section>

  <div class="page-header">
    <h2 class="page-title">About Me</h2>
    <%= link_to resume_download_path,
      class: "btn",
      target: "_blank",
      data: { turbo: false } do %>
      <svg class="btn-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 20h14v-2H5v2zm7-18v12l4-4h-3V4h-2v6H8l4 4z"/>
      </svg>
      Download Resume
    <% end %>
  </div>

  <p class="body-text">
  I'm Joshua Zink-Duda, a software engineer who thrives on tackling ambiguous systems and turning them into something clear and maintainable.
  I enjoy automating tedious processes, eliminating friction, and designing solutions that scale.
  What motivates me most is applying these skills to problems that matter and projects where good engineering creates a positive impact on the world.
  </p>

  <h2 class="skills-heading">Skills</h2>
  <% skills_data.each_value do |section| %>
    <%= skill_section(section["title"], section["skills"]) %>
  <% end %>
</section>
