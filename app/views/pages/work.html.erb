<section>

  <div class="page-header">
    <h2 class="page-title">My Work</h2>
    <%= link_to resume_download_path,
      class: "btn",
      target: "_blank",
      data: { turbo: false } do %>
      <svg class="btn-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 20h14v-2H5v2zm7-18v12l4-4h-3V4h-2v6H8l4 4z"/>
      </svg>
      Download Resume
    <% end %>
  </div>

  <div class="work-list">
    <% @work_experiences.each do |job| %>
      <div class="work-card">
        <h2><%= job["role"] %> at <%= job["company"] %></h2>
        <p class="timeframe"><%= job["timeframe"] %></p>
        <p class="summary"><%= job["summary"] %></p>

        <ul class="projects">
          <% job["projects"].each do |project| %>
            <li>
              <strong><%= project["name"] %>:</strong>
              <span class="description"><%= project["description"] %></span>
              <% if project["tech"] %>
                <div class="tech-tags">
                  <% project["tech"]&.each do |tech| %>
                    <span class="tech-tag"><%= tech %></span>
                  <% end %>
                </div>
              <% else %>
                <div class="project-spacer"></div>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</section>
