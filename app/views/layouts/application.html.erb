<!DOCTYPE html>
<html>
  <head>
    <title>Joshua Zink-Duda | Software Engineer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="description" content="Joshua Zink-Duda, Software Engineer with expertise in backend development, APIs, and system architecture">

    <meta property="og:title" content="Joshua Zink-Duda – Software Engineer">
    <meta property="og:description" content="Joshua Zink-Duda, Software Engineer with expertise in backend development, APIs, and system architecture">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://joshua.zink-duda.com/">
    <%# <meta property="og:image" content="https://yourdomain.com/social-preview.png"> %>


    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# <link rel="icon" href="/icon.png" type="image/png"> %>
    <%# <link rel="icon" href="/icon.svg" type="image/svg+xml"> %>
    <link rel="shortcut icon" href="<%= asset_path 'favicon.ico' %>" type="image/x-icon">
    <link rel="icon" href="<%= asset_path 'favicon.ico' %>" type="image/x-icon">
    <%# <link rel="apple-touch-icon" href="/icon.png"> %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <div class="container">
        <%= link_to "Joshua Zink-Duda", root_path, class: "site-title" %>
        <nav>
          <%= link_to "About", about_path, class: "nav-link" %>
          <%= link_to "Work", work_path, class: "nav-link" %>
          <%= link_to "Contact", contact_path, class: "nav-link" %>
        </nav>
      </div>
    </header>

    <main class="container">
      <%= yield %>
    </main>

    <footer>
      <div class="container">
        <p>&copy; <%= Time.now.year %> Joshua Zink-Duda</p>
    </footer>
  </body>
</html>
